{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Penflow",
    "version": "0.1.3",
    "identifier": "dev.penflow.gui",
    "build": {
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../ui/dist"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Penflow",
                "width": 720,
                "height": 720,
                "minWidth": 640,
                "minHeight": 640,
                "resizable": true,
                "fullscreen": false,
                "decorations": true,
                "transparent": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": ["msi"],
        "icon": [
            "icons/32x32.png",
            "icons/64x64.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.ico",
            "icons/icon.png"
        ],
        "publisher": "Penflow",
        "shortDescription": "PC→Android pen-display bridge",
        "longDescription": "Streams the desktop to an Android pen-display tablet over a USB ADB tunnel, with full Windows Ink pressure/tilt input back to the PC.",
        "category": "Productivity",
        "resources": {
            "../../../installer/vdd-driver/MttVDD.inf":  "vdd/MttVDD.inf",
            "../../../installer/vdd-driver/MttVDD.dll":  "vdd/MttVDD.dll",
            "../../../installer/vdd-driver/mttvdd.cat":  "vdd/mttvdd.cat",
            "../../../installer/vdd-driver/devcon.exe":  "vdd/devcon.exe",
            "../../../tools/vdd/vdd_settings.xml":       "vdd/vdd_settings.xml",
            "../../../installer/adb/adb.exe":            "adb/adb.exe",
            "../../../installer/adb/AdbWinApi.dll":      "adb/AdbWinApi.dll",
            "../../../installer/adb/AdbWinUsbApi.dll":   "adb/AdbWinUsbApi.dll",
            "../../../installer/vmulti-driver/vmulti.sys":              "vmulti/vmulti.sys",
            "../../../installer/vmulti-driver/vmulti.inf":              "vmulti/vmulti.inf",
            "../../../installer/vmulti-driver/pentablethid.cat":        "vmulti/pentablethid.cat",
            "../../../installer/vmulti-driver/hidkmdf.sys":             "vmulti/hidkmdf.sys",
            "../../../installer/vmulti-driver/WdfCoInstaller01009.dll": "vmulti/WdfCoInstaller01009.dll",
            "../../../installer/vmulti-driver/devcon.exe":              "vmulti/devcon.exe",
            "../../../installer/vmulti-driver/DIFxCmd.exe":             "vmulti/DIFxCmd.exe",
            "../../../installer/vmulti-driver/DIFxAPI.dll":             "vmulti/DIFxAPI.dll"
        },
        "windows": {
            "wix": {
                "language": "en-US",
                "fragmentPaths": ["wix/vdd-install.wxs", "wix/vmulti-install.wxs"],
                "componentRefs": ["PenflowVddInstallActions", "PenflowVmultiInstallActions"]
            }
        }
    }
}
